# ============================================================
# CINTENT PLATFORM V2 - ENVIRONMENT VARIABLES
# ============================================================

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL with pgvector)
DB_HOST=localhost
DB_PORT=5432
DB_USER=cintent_user
DB_PASSWORD=your-secure-password-here
DB_NAME=cintent_platform

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Stripe Payment Processing
STRIPE_PUBLIC_KEY=pk_live_your_public_key_here
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# OpenAI / Claude API (for Ask COGNI)
OPENAI_API_KEY=sk-your-openai-key-here
# OR for Claude:
CLAUDE_API_KEY=sk-ant-your-claude-key-here

# Ask COGNI Configuration
COGNI_MODEL=gpt-4
COGNI_TEMPERATURE=0.7
COGNI_MAX_TOKENS=2000

# CORS & Security
CORS_ORIGINS=https://api-cintent.cognivantalabs.com,https://cintent.cognivantalabs.com,https://cognivantalabs.com

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/cintent.log

# Feature Flags
ENABLE_SIMULATED_EXECUTION=true
ENABLE_REPLAY_SERVICE=true
ENABLE_GOVERNANCE_ENFORCEMENT=true
ENABLE_OBSERVABILITY_METRICS=true
